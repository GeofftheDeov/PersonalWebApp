{
    "family": "personal-web-app-task-definition",
    "containerDefinitions": [
        {
            "name": "backend",
            "image": "913447902637.dkr.ecr.us-east-2.amazonaws.com/personal-web-app-backend",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "backend-5000-tcp",
                    "containerPort": 5000,
                    "hostPort": 5000,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "FRONTEND_URL",
                    "value": "https://geoffthedeov.net"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/personal-web-app-task-definition",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-2",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        },
        {
            "name": "mongodb",
            "image": "913447902637.dkr.ecr.us-east-2.amazonaws.com/personal-web-app-mongodb",
            "cpu": 0,
            "portMappings": [],
            "essential": false,
            "environment": [],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "systemControls": []
        },
        {
            "name": "frontend",
            "image": "913447902637.dkr.ecr.us-east-2.amazonaws.com/personal-web-app-frontend",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "frontend-http",
                    "containerPort": 3000,
                    "hostPort": 3000,
                    "protocol": "tcp",
                    "appProtocol": "http"
                },
                {
                    "name": "frontend-https",
                    "containerPort": 3001,
                    "hostPort": 3001,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": false,
            "environment": [
                {
                    "name": "BACKEND_URL",
                    "value": "http://localhost:5000"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "systemControls": []
        }
    ],
    "executionRoleArn": "arn:aws:iam::913447902637:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "3072",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}