SF_LOGIN_URL=https://login.salesforce.com
SF_USERNAME=your-salesforce-username
SF_PASSWORD=your-salesforce-password
SF_TOKEN=your-salesforce-token
SF_CLIENT_ID=your-salesforce-client-id
SF_PRIVATE_KEY_PATH=certs/server.key
JWT_SECRET=your-super-secret-jwt-key
MONGO_URI=mongodb://localhost:27017/personal_web_app

# Email Service
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_SERVICE=gmail
FRONTEND_URL=http://0.0.0.0:3000

# API Key for server-to-server syncs (e.g., Salesforce)
SYNC_API_KEY=your-secure-api-key-here

# Alpaca paper trading (used by Cloud-Claw agent and the Alpaca dashboard)
ALPACA_API_KEY=your-alpaca-paper-key-id
ALPACA_SECRET_KEY=your-alpaca-paper-secret

# Google Calendar OAuth (event creation) — same Google Cloud project as sign-in.
# Add <FRONTEND_URL>/api/google-calendar/callback as an authorized redirect URI.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Optional override; defaults to FRONTEND_URL + /api/google-calendar/callback
# GOOGLE_REDIRECT_URI=

# API Key Vault encryption — required to store per-user keys
# Must be exactly 32 UTF-8 bytes OR a 64-character lowercase hex string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_ENCRYPTION_KEY=your-32-byte-or-64-char-hex-key-here

# Obsidian vault (EFS mount path in production)
OBSIDIAN_VAULT_PATH=/obsidian-vault
