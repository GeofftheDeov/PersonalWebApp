{
    "family": "personal-web-app-redis",
    "containerDefinitions": [
        {
            "name": "redis",
            "image": "redis:7-alpine",
            "cpu": 256,
            "memory": 512,
            "portMappings": [
                {
                    "containerPort": 6379,
                    "hostPort": 6379,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "command": [
                "redis-server",
                "--appendonly", "yes",
                "--appendfsync", "everysec",
                "--dir", "/data"
            ],
            "environment": [],
            "environmentFiles": [],
            "mountPoints": [
                {
                    "sourceVolume": "redis-data",
                    "containerPath": "/data",
                    "readOnly": false
                }
            ],
            "volumesFrom": [],
            "systemControls": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/personal-web-app-redis",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-2",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            }
        }
    ],
    "volumes": [
        {
            "name": "redis-data",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-0823aab1d7700df09",
                "rootDirectory": "/redis-data",
                "transitEncryption": "ENABLED"
            }
        }
    ],
    "taskRoleArn": "arn:aws:iam::913447902637:role/ecsTaskRole",
    "executionRoleArn": "arn:aws:iam::913447902637:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "runtimePlatform": {
        "cpuArchitecture": "ARM64",
        "operatingSystemFamily": "LINUX"
    }
}
