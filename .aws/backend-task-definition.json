{
    "family": "personal-web-app-task-definition",
    "containerDefinitions": [
        {
            "name": "backend",
            "image": "913447902637.dkr.ecr.us-east-2.amazonaws.com/personal-web-app-backend",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "backend-5000-tcp",
                    "containerPort": 5000,
                    "hostPort": 5000,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "FRONTEND_URL",
                    "value": "https://geoffthedeov.net"
                },
                {
                    "name": "EMAIL_USER",
                    "value": "geoffrey.murray.1995@gmail.com"
                },
                {
                    "name": "EMAIL_SERVICE",
                    "value": "gmail"
                },
                {
                    "name": "EMAIL_PASS",
                    "value": ""
                },
                {
                    "name": "JWT_SECRET",
                    "value": ""
                },
                {
                    "name": "MONGO_URI",
                    "value": "mongodb://localhost:27017/personal_web_app"
                },
                {
                    "name": "SF_LOGIN_URL",
                    "value": "https://login.salesforce.com"
                },
                {
                    "name": "SF_USERNAME",
                    "value": "personalwebapp@murrayllc.com"
                },
                {
                    "name": "SF_PASSWORD",
                    "value": ""
                },
                {
                    "name": "SF_CLIENT_ID",
                    "value": ""
                },
                {
                    "name": "SF_PRIVATE_KEY_CONTENT",
                    "value": ""
                },
                {
                    "name": "SYNC_API_KEY",
                    "value": ""
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/personal-web-app-task-definition",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-2",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        },
        {
            "name": "mongodb",
            "image": "mongo:7.0",
            "cpu": 256,
            "memoryReservation": 512,
            "portMappings": [
                {
                    "containerPort": 27017,
                    "hostPort": 27017,
                    "protocol": "tcp"
                }
            ],
            "command": [
                "sh",
                "-c",
                "rm -f /data/db/*.lock /data/db/WiredTiger.lock && mongod --fork --logpath /var/log/mongodb.log --bind_ip_all && mongodump --out /data/db/migration_dump && tail -f /var/log/mongodb.log"
            ],
            "essential": true,
            "environment": [],
            "environmentFiles": [],
            "mountPoints": [
                {
                    "sourceVolume": "mongodb-data",
                    "containerPath": "/data/db",
                    "readOnly": false
                }
            ],
            "volumesFrom": [],
            "systemControls": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/personal-web-app-task-definition",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-2",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            }
        },
        {
            "name": "frontend",
            "image": "913447902637.dkr.ecr.us-east-2.amazonaws.com/personal-web-app-frontend",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "frontend-http",
                    "containerPort": 3000,
                    "hostPort": 3000,
                    "protocol": "tcp",
                    "appProtocol": "http"
                },
                {
                    "name": "frontend-https",
                    "containerPort": 3001,
                    "hostPort": 3001,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": false,
            "environment": [
                {
                    "name": "BACKEND_URL",
                    "value": "http://localhost:5000"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "systemControls": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/personal-web-app-task-definition",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-2",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            }
        }
    ],
    "volumes": [
        {
            "name": "mongodb-data",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-0823aab1d7700df09",
                "rootDirectory": "/"
            }
        }
    ],
    "taskRoleArn": "arn:aws:iam::913447902637:role/ecsTaskRole",
    "executionRoleArn": "arn:aws:iam::913447902637:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "3072",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}