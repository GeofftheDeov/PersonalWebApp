# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must always check out with LF — CRLF breaks the shebang in Docker
*.sh text eol=lf
*.node filter=lfs diff=lfs merge=lfs -text
frontend/node_modules/@next/swc-win32-x64-msvc/next-swc.win32-x64-msvc.node filter=lfs diff=lfs merge=lfs -text
